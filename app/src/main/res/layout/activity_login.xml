<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ai_neural">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- LOGO -->

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/logo_mymodels"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:text="MyModels"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"/>

        <TextView
            android:text="Run AI models locally"
            android:textColor="#A5B4FC"
            android:layout_marginBottom="30dp"/>

        <!-- Glass Card -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card">

            <EditText
                android:hint="Email"
                android:textColor="#FFFFFF"
                android:hintTextColor="#94A3B8"
                android:layout_width="match_parent"
                android:layout_height="48dp"/>

            <EditText
                android:hint="Password"
                android:textColor="#FFFFFF"
                android:hintTextColor="#94A3B8"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"/>

            <Button
                android:text="Login"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"/>
             
            <!-- neural network -->

            <com.mymodels.ui.NeuralBackgroundView
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- GitHub button -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/btn_github">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_github"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:text="Continue with GitHub"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>