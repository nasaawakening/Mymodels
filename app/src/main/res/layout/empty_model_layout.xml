<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#000000">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_ai"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activate Model To Get Started"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="Select the model and download it. After downloading, tap Load next to the model and start chatting."
        android:textColor="#AAAAAA"
        android:textAlignment="center"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnSelectModel"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="Select Model"
        android:layout_marginTop="20dp"
        android:backgroundTint="#DDDDDD"
        android:textColor="#000000"/>

</LinearLayout>